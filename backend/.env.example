# Required — MongoDB Atlas connection string
# Network Access in Atlas: allow 0.0.0.0/0 (Vercel uses dynamic IPs)
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=nihongo_app

# Required — long random string for JWT signing
SECRET_KEY=change-this-to-a-long-random-string

# Required for AI Sensei chat
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated frontend origins (add your Netlify URL after deploy)
ALLOWED_ORIGINS=http://localhost:5173,https://your-site.netlify.app
